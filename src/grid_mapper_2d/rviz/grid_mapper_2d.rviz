      Decay Time: 0
      Enabled: true
      Invert Rainbow: false
      Max Color: 255; 255; 255
      Max Intensity: 4096
      Min Color: 0; 0; 0
      Min Intensity: 0
      Name: World Cloud
      Position Transformer: XYZ
      Selectable: true
      Size (Pixels): 5
